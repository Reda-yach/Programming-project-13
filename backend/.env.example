# Backend configuratie — kopieer dit bestand naar .env en vul de echte waarden in.
# .env zelf staat in .gitignore en mag NOOIT gecommit worden.

# Poort waarop de Express-server draait
PORT=3000

# MySQL database-verbinding
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=stageverloop

# Geheim voor het ondertekenen van JWT-tokens (lange, willekeurige string)
JWT_SECRET=verander-dit-naar-een-lange-random-string
